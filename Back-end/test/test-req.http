# Test HTTP requests
### for use with: REST Client extension
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..GEI4eQnEcKgWq78ElEJczNRa-T1SWL0v3RCfYn8NmXs
### Add new item

POST http://localhost:3000/api/items
Content-Type: application/json

{"name": "Six Seven"}

### Put new item

PUT http://localhost:3000/api/items/
Content-Type: application/json

{"id": 5, "name": "mauku"}


### Delete last item

DELETE http://localhost:3000/api/items/:id
Content-Type: application/json

{"id": 4}


### users endpoints

### Get all users
GET http://localhost:3000/api/users
Authorization: Bearer {{token}}

### Get username by ID
GET http://localhost:3000/api/users/2

### Register new user
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "megis67",
  "password": "jessejesseb",
  "email": "jesse2@example.com"
}

### User login
POST http://localhost:3000/api/users/login
Content-Type: application/json

{
  "username": "",
  "password": ""
}

### Get user info by token
GET http://localhost:3000/api/users/me
Authorization: Bearer {{token}}

### Diary entry endpoints

### Get all entries
GET http://localhost:3000/api/entries
Authorization: Bearer: {{token}}

### Get entry by ID

GET http://localhost:3000/api/entries/18

### Delete Entry by ID
DELETE http://localhost:3000/api/entries/11
Authorization: Bearer {{token}}

### Post new entry

POST http://localhost:3000/api/entries
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "entry_date": "2026-03-09",
  "mood": "Mukava päivä",
  "weight": 76,
  "sleep_hours": 8,
  "notes": "Jeejee kivaa"
}

### Hae Kubios dataa
GET http://localhost:3000/api/kubios/user-data
Authorization: Bearer {{token}}

### Get Kubios Info

GET http://localhost:3000/api/kubios/user-info
Authorization: Bearer {{token}}
